<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Target .NET Framework 4.8 for System.Media.SoundPlayer (WAV playback) -->
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>CybersecurityChatbot</AssemblyName>
    <RootNamespace>CybersecurityChatbot</RootNamespace>
    <Nullable>disable</Nullable>
    <LangVersion>7.3</LangVersion>
  </PropertyGroup>

  <!-- Copy the WAV file to the output directory automatically on build -->
  <ItemGroup>
    <Content Include="greeting.wav" Condition="Exists('greeting.wav')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <None Update="greeting.wav">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
